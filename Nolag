local function load(url)
    local ok, res = pcall(function()
        return game:HttpGet(url)
    end)

    if not ok then
        warn("Failed to fetch script")
        return
    end

    local fn = loadstring(res)
    if fn then
        pcall(fn)
    else
        warn("Loadstring failed")
    end
end

